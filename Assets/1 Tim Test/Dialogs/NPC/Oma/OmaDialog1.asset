      skipsQuest: 0
      questIDToSkip: 0
      addsSequenceValue: 0
      sequenceValue: 0
      checksSequence: 0
      sequenceChecker: {fileID: 0}
  - dialogueText: "Vater:  ich br\xE4uchte auch noch deine Hilfe. Ich hatte\r\ndir
