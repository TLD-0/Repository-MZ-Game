      skipsQuest: 0
      questIDToSkip: 0
      addsSequenceValue: 0
      sequenceValue: 0
      checksSequence: 0
      sequenceChecker: {fileID: 0}
  - dialogueText: "Mutter: \u201CWenn du schon dabei bist, kannst\r\ndu auch die
