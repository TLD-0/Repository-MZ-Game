      skipsQuest: 0
      questIDToSkip: 0
      addsSequenceValue: 0
      sequenceValue: 0
      checksSequence: 0
      sequenceChecker: {fileID: 0}
  - dialogueText: "Mutter: Und au\xDFerdem liegen deine ganzen B\xFCcher auf\r\ndem
