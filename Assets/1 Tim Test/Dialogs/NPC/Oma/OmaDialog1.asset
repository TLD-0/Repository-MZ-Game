      questIDToSkip: 0
      addsSequenceValue: 0
      sequenceValue: 0
      checksSequence: 0
      sequenceChecker: {fileID: 0}
    - answerText: "Aber du wei\xDFt doch, dass ich fr\xFCh schlafen gehen muss.."
